// Juno HPC SLURM configuration for epi2me-labs/wf-transcriptomes
// Sourced via -c flag by wf_transcriptomes_slurm_template.sh.
// Do not edit executor/singularity blocks without testing on Juno first.

process {
    executor = 'slurm'
    queue    = 'normal'

    // EPI2ME standard resource labels (used across all wf-* workflows)
    withLabel: 'process_low' {
        cpus   = 2
        memory = '4 GB'
        time   = '4h'
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8 GB'
        time   = '8h'
    }
    withLabel: 'process_high' {
        cpus   = 16
        memory = '32 GB'
        time   = '24h'
    }
    withLabel: 'process_high_memory' {
        cpus   = 8
        memory = '64 GB'
        time   = '24h'
    }
}

singularity {
    enabled    = true
    autoMounts = true
    // Shared per-user container cache — images pulled once and reused across runs
    cacheDir   = "/scratch/juno/${System.getenv('USER')}/nf_containers"
    // Explicit bind mounts for Juno filesystem layout (no symlinks in bind paths)
    runOptions = '--bind /groups/tprice --bind /work --bind /scratch/juno'
}

executor {
    name            = 'slurm'
    queueSize       = 100           // max concurrent SLURM jobs submitted by Nextflow
    submitRateLimit = '10/1min'     // avoid overwhelming SLURM scheduler
    pollInterval    = '2 min'       // how often Nextflow checks job status
    // Prefix job names for easy identification in squeue
    jobName         = { "wftx_${task.process.tokenize(':').last()}" }
}
